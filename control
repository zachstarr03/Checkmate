// move to destination square first to take the piece
void takePiece(char file2, int rank2) {

    int column = file2 - 'a';
    int row = 8 - rank2;

    if (column < 0 || column > 7 || row < 0 || row > 7) {
        Serial.println("Invalid square.");
        return;
    }

    Serial.print("Moving to take: "); Serial.print(file2); Serial.println(rank2);
    
    //moveServoIncremental(LEFT_SHOULDER_MOTOR, homeLeftShoulderMotor, chessBoard[row][column][1]);
    //moveServoIncremental(RIGHT_SHOULDER_MOTOR, homeRightShoulderMotor, chessBoard[row][column][2]);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, homeLeftShoulderMotor, 115);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, homeRightShoulderMotor, 50);
    delay(150);
    //moveServoIncremental(ELBOW_MOTOR, homeElbowMotor, chessBoard[row][column][3]);
    moveServoIncremental(ELBOW_MOTOR, homeElbowMotor, 40);
    delay(150);
    moveServoIncremental(CLAW_WRIST, homeClawWristMotor, chessBoard[row][column][4]);
    delay(150);
    moveServoIncremental(BASE_MOTOR, homeBaseMotor, chessBoard[row][column][0]);
    delay(150);
    moveServoIncremental(CLAW_MOTOR, homeClawMotor, chessBoard[row][column][5]);
    delay(150);

    // move the arm down gently without hitting other pieces
    moveServoIncremental(LEFT_SHOULDER_MOTOR, 115, chessBoard[row][column][1]);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, 50, chessBoard[row][column][2]);
    moveServoIncremental(ELBOW_MOTOR, 40, chessBoard[row][column][3]);
    delay(150);

    // close claw
    moveServoIncremental(CLAW_MOTOR, chessBoard[row][column][5], homeClawMotor);
    delay(150);

    // move piece to collection bucket and move elbow upwards so no pieces are bumped
    moveServoIncremental(ELBOW_MOTOR, chessBoard[row][column][3], 40);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, chessBoard[row][column][1], 135);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, chessBoard[row][column][2], 45);
    delay(300);

    moveServoIncremental(BASE_MOTOR, chessBoard[row][column][0], homeBaseMotor);
    delay(150);

    // position elbow, and wrist to be in position to drop a piece into the bin
    moveServoIncremental(ELBOW_MOTOR, 40, homeElbowMotor);
    delay(150);

    // oepn claw
    moveServoIncremental(CLAW_MOTOR, homeClawMotor, chessBoard[row][column][5]);
    delay(150);
    // close claw again
    moveServoIncremental(CLAW_MOTOR, chessBoard[row][column][5], homeClawMotor);
    delay(150);

    moveServoIncremental(CLAW_WRIST, chessBoard[row][column][4], homeClawWristMotor);
    delay(150);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, 135, homeLeftShoulderMotor);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, 45, homeRightShoulderMotor);
    delay(300);

    Serial.print("Base Motor Angle: ");
    Serial.print(chessBoard[row][column][0]);
    Serial.print(", Left Motor Angle: ");
    Serial.print(chessBoard[row][column][1]);
    Serial.print(", Right Motor Angle: ");
    Serial.print(chessBoard[row][column][2]);
    Serial.print(", Elbow Motor Angle: ");
    Serial.print(chessBoard[row][column][3]);
    Serial.print(", Claw Wrist Motor Angle: ");
    Serial.print(chessBoard[row][column][4]);
    Serial.print(", Claw Motor Angle: ");
    Serial.print(chessBoard[row][column][5]);

}

// move to origin square
void moveToSquare(char file, int rank) {

    int column = file - 'a';
    int row = 8 - rank;

    if (column < 0 || column > 7 || row < 0 || row > 7) {
        Serial.println("Invalid square.");
        return;
    }

    Serial.print("Moving to: "); Serial.print(file); Serial.println(rank);


    //moveServoIncremental(LEFT_SHOULDER_MOTOR, homeLeftShoulderMotor, chessBoard[row][column][1]);
    //moveServoIncremental(RIGHT_SHOULDER_MOTOR, homeRightShoulderMotor, chessBoard[row][column][2]);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, homeLeftShoulderMotor, 115);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, homeRightShoulderMotor, 50);
    delay(150);
    //moveServoIncremental(ELBOW_MOTOR, homeElbowMotor, chessBoard[row][column][3]);
    moveServoIncremental(ELBOW_MOTOR, homeElbowMotor, 40);
    delay(150);
    moveServoIncremental(CLAW_WRIST, homeClawWristMotor, chessBoard[row][column][4]);
    delay(150);
    moveServoIncremental(BASE_MOTOR, homeBaseMotor, chessBoard[row][column][0]);
    delay(150);
    moveServoIncremental(CLAW_MOTOR, homeClawMotor, chessBoard[row][column][5]);
    delay(150);

    // move the arm down gently without hitting other pieces
    moveServoIncremental(LEFT_SHOULDER_MOTOR, 115, chessBoard[row][column][1]);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, 50, chessBoard[row][column][2]);
    moveServoIncremental(ELBOW_MOTOR, 40, chessBoard[row][column][3]);
    delay(150);

    Serial.print("Base Motor Angle: ");
    Serial.print(chessBoard[row][column][0]);
    Serial.print(", Left Motor Angle: ");
    Serial.print(chessBoard[row][column][1]);
    Serial.print(", Right Motor Angle: ");
    Serial.print(chessBoard[row][column][2]);
    Serial.print(", Elbow Motor Angle: ");
    Serial.print(chessBoard[row][column][3]);
    Serial.print(", Claw Wrist Motor Angle: ");
    Serial.print(chessBoard[row][column][4]);
    Serial.print(", Claw Motor Angle: ");
    Serial.print(chessBoard[row][column][5]);

    lastRow = row;
    lastColumn = column;

}

// move to destination square
void moveToSquare2(char file2, int rank2) {

    int newColumn = file2 - 'a';
    int newRow = 8 - rank2;

    if (lastRow == -1 || lastColumn == -1) {
        Serial.println("No previous move to return from.");
        return;
    }
    if (newColumn < 0 || newColumn > 7 || newRow < 0 || newRow > 7) {
        Serial.println("Invalid square.");
        return;
    }

    Serial.print("Moving to: "); Serial.print(file2); Serial.println(rank2);
    
    //close claw
    moveServoIncremental(CLAW_MOTOR, chessBoard[lastRow][lastColumn][5], homeClawMotor);
    delay(150);

    //move elbow upwards so no pieces are bumped
    moveServoIncremental(ELBOW_MOTOR, chessBoard[lastRow][lastColumn][3], 40);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, chessBoard[lastRow][lastColumn][1], 135);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, chessBoard[lastRow][lastColumn][2], 45);
    delay(300);
    moveServoIncremental(BASE_MOTOR, chessBoard[lastRow][lastColumn][0], chessBoard[newRow][newColumn][0]);
    delay(150);
    moveServoIncremental(ELBOW_MOTOR, 40, chessBoard[newRow][newColumn][3]);
    delay(150);
    moveServoIncremental(CLAW_WRIST, chessBoard[lastRow][lastColumn][4], chessBoard[newRow][newColumn][4]);
    delay(150);

    moveServoIncremental(LEFT_SHOULDER_MOTOR, 135, chessBoard[newRow][newColumn][1]);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, 45, chessBoard[newRow][newColumn][2]);

    //re open the claw 
    moveServoIncremental(CLAW_MOTOR, homeClawMotor, chessBoard[newRow][newColumn][5]);
    delay(150);

    Serial.print("Base Motor Angle: ");
    Serial.print(chessBoard[newRow][newColumn][0]);
    Serial.print(", Left Motor Angle: ");
    Serial.print(chessBoard[newRow][newColumn][1]);
    Serial.print(", Right Motor Angle: ");
    Serial.print(chessBoard[newRow][newColumn][2]);
    Serial.print(", Elbow Motor Angle: ");
    Serial.print(chessBoard[newRow][newColumn][3]);
    Serial.print(", Claw Wrist Motor Angle: ");
    Serial.print(chessBoard[newRow][newColumn][4]);
    Serial.print(", Claw Motor Angle: ");
    Serial.print(chessBoard[newRow][newColumn][5]);

    lastRow2 = newRow;
    lastColumn2 = newColumn;

}

// return to defined home position
void returnToHome() {

    if (lastRow2 == -2 || lastColumn2 == -2) {
        Serial.println("No previous move to return from.");
        return;
    }

    Serial.println("\nReturning to home position...");

    //move elbow upwards so no pieces are bumped
    moveServoIncremental(ELBOW_MOTOR, chessBoard[lastRow2][lastColumn2][3], 40);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, chessBoard[lastRow2][lastColumn2][1], 135);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, chessBoard[lastRow2][lastColumn2][2], 45);
    delay(300);
    
    //close claw 
    moveServoIncremental(CLAW_MOTOR, chessBoard[lastRow2][lastColumn2][5], homeClawMotor);
    delay(150);
    moveServoIncremental(BASE_MOTOR, chessBoard[lastRow2][lastColumn2][0], homeBaseMotor);
    delay(150);
    moveServoIncremental(ELBOW_MOTOR, 40, homeElbowMotor);
    delay(150);
    moveServoIncremental(CLAW_WRIST, chessBoard[lastRow2][lastColumn2][4], homeClawWristMotor);
    delay(150);
    moveServoIncremental(LEFT_SHOULDER_MOTOR, 135, homeLeftShoulderMotor);
    moveServoIncremental(RIGHT_SHOULDER_MOTOR, 45, homeRightShoulderMotor);

    Serial.print("Base Motor Angle: ");
    Serial.print(homeBaseMotor);
    Serial.print(", Left Motor Angle: ");
    Serial.print(homeLeftShoulderMotor);
    Serial.print(", Right Motor Angle: ");
    Serial.print(homeRightShoulderMotor);
    Serial.print(", Elbow Motor Angle: ");
    Serial.print(homeElbowMotor);
    Serial.print(", Claw Wrist Motor Angle: ");
    Serial.print(homeClawWristMotor);
    Serial.print(", Claw Motor Angle: ");
    Serial.print(homeClawMotor);

    Serial.println("\nHome position reached.");
}

void setup() {

    Serial.begin(9600);
    pwm.begin();
    pwm.setPWMFreq(50);

    Serial.println("Initializing servos...");

    delay(1000);
    returnToHome();

}

void loop() {

    // Stockfish sending moves
    if (Serial.available() > 0) {

        String input = Serial.readStringUntil('\n');  // Read until newline

        if (input.endsWith("k")) {
            isCapture = true;
        }

        // queenside castle
        if (input == "e8c8") {
            isQueenSideCastle = true;
        }

        // kingside caslt
        if (input == "e8g8") {
            isKingSideCastle = true;
        }

        char file = input.charAt(0);         // Get 'e'
        int rank = input.charAt(1) - '0';    // Get '2'
        char file2 = input.charAt(2);        // Get 'e'  
        int rank2 = input.charAt(3) - '0';   // Get '4'               

        Serial.print("ORIGIN SQUARE LETTER: " + file);
        Serial.print("ORIGIN SQUARE NUMBER: " + rank);
        Serial.print("DEST SQUARE LETTER: " + file2);
        Serial.print("DEST SQUARE NUMBER: " + rank2);

        // regular move
        if (isCapture == false && isQueenSideCastle == false && isKingSideCastle == false) {

            if (file >= 'a' && file <= 'h' && rank >= 1 && rank <= 8 && file2 >= 'a' && file2 <= 'h' && rank2 >= 1 && rank2 <= 8) {
                moveToSquare(file, rank);
                delay(2000);
                Serial.println("First Move completed");
                delay(2000);
                moveToSquare2(file2, rank2);
                delay(2000);
                Serial.println("Second Move completed");
                delay(2000);
                returnToHome();

            } else {
                Serial.println("Invalid square.");
            }
        }

        // Take a piece
        if (isCapture == true) {
       
            takePiece(file2, rank2);
            delay(2000);
            Serial.println("Piece Taken");
            moveToSquare(file, rank);
            delay(2000);
            Serial.println("First Move complete");
            moveToSquare2(file2, rank2);
            delay(2000);
            Serial.println("Second Move complete");
            delay(2000);
            returnToHome();

            isCapture = false;

        }

        // Queenside castle logic
        if (isQueenSideCastle == true) {
                    
            moveToSquare(file, rank);
            delay(2000);
            Serial.println("First Move complete");
            moveToSquare2(file2, rank2);
            delay(2000);
            Serial.println("Second Move complete");
            delay(2000);
            returnToHome();

            Serial.println("Castling Queen side...");
            moveToSquare('a', 8);
            delay(2000);
            Serial.println("First Move complete");
            moveToSquare2('d', 8);
            delay(2000);
            Serial.println("Second Move complete");
            delay(2000);
            returnToHome();

            isQueenSideCastle = false;

        }

        // Kingside castle logic
        if (isKingSideCastle == true) {

            moveToSquare(file, rank);
            delay(2000);
            Serial.println("First Move complete");
            moveToSquare2(file2, rank2);
            delay(2000);
            Serial.println("Second Move complete");
            delay(2000);
            returnToHome();

            Serial.println("Castling King side...");
            moveToSquare('h', 8);
            delay(2000);
            Serial.println("First Move complete");
            moveToSquare2('f', 8);
            delay(2000);
            Serial.println("Second Move complete");
            delay(2000);
            returnToHome();

            isKingSideCastle = false;

        }

        Serial.println("Received:" + input);        // Echo full message

    }
    
}

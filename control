/** ARDUINO PROGRAM USING A PCA9865 MOTOR DRIVER **/

#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>

Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver(0x40);

#define BASE_MOTOR 0
#define LEFT_SHOULDER_MOTOR 2
#define RIGHT_SHOULDER_MOTOR 4
#define ELBOW_MOTOR 6
#define CLAW_WRIST 8
#define CLAW_MOTOR 10

#define SERVO_MIN  150  
#define SERVO_MAX  600  

// booleans for capture, and castle logic
bool isCapture = false;
bool isQueenSideCastle = false;
bool isKingSideCastle = false;

// values to keep for saving angles in between moves
int lastRow = -1;
int lastColumn = -1;

// values to keep for saving angles to return to home position
int lastRow2 = -2;
int lastColumn2 = -2;

/** Zeroing values **/
int baseMotor = 0;
int leftShoulderMotor = 10;  
int rightShoulderMotor = 155;  
int elbowMotor = 0;
int clawWristMotor = 0;
int clawMotor = 110;

/** Home Positions **/
int homeBaseMotor = 0;
int homeLeftShoulderMotor = 90;
int homeRightShoulderMotor = 75;
int homeElbowMotor = 100;
int homeClawWristMotor = 10;
int homeClawMotor = 105;


// function to move the servos
void moveServoIncremental(int servoChannel, int currentAngle, int targetAngle) {

    // targetAngle = round(targetAngle / 5.0) * 5;  // Round to nearest 5 degrees
    targetAngle = round(targetAngle);
    if (currentAngle < targetAngle) {
        for (int angle = currentAngle; angle <= targetAngle; angle += 1) {
            pwm.setPWM(servoChannel, 0, map(angle, 0, 180, SERVO_MIN, SERVO_MAX));
            delay(50);
        }
    } else {

        for (int angle = currentAngle; angle >= targetAngle; angle -= 1) {
            pwm.setPWM(servoChannel, 0, map(angle, 0, 180, SERVO_MIN, SERVO_MAX));
            delay(50);
        }
    }
}

// Chessboard target angles
int chessBoard[8][8][6] = { 

    //increasing wrist makes it come closer to the base
    //decreasing elbow makes it go up away from the base
    //left shoulder down, right shoulder up, elbow up, wrist down
    // a8 -> h8
    //a8 is good                     //b8 is good                  //c8 is good                   //d8 is good                   //e8 is good                   //f8 is good                    //g8 is good                    //h8 is good
    { { 41, 119, 46, 109, 75, 150}, { 51, 120, 45, 110, 81, 150}, { 62, 116, 49, 108, 90, 150 }, { 79, 135, 30, 116, 89, 150 }, { 92, 128, 37, 110, 92, 150 }, { 105, 122, 43, 108, 88, 150 }, { 117, 116, 49, 105, 86, 150 }, { 125, 118, 47, 108, 74, 150 } },
